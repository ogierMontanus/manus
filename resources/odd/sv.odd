                 <elementSpec ident="titlePage" mode="change">
                    <model behaviour="section" useSourceRendition="true">
            <desc>TEI-Publisher standard seems to be div type="title_page". 2024-03-13: added font from MT. Removed grey, added border</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
