<?xml-model href="teipublisher_odds.xsd"?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:pb="http://teipublisher.com/1.0" xml:lang="en">
    <teiHeader>
        <fileDesc>
            <titleStmt>
                <title>SV</title>
            </titleStmt>
            <publicationStmt>
                <publisher>eXistSolutions GmbH</publisher>
                <availability>
                    <licence target="https://www.gnu.org/licenses/gpl-3.0.en.html">Distributed under GNU General Public License</licence>
                    <p>Copyright 2017 <ref target="http://existsolutions.com">eXistSolutions GmbH</ref>
                    </p>
                    <p>This program is free software: you can redistribute it and/or modify
                        it under the terms of the GNU General Public License as published by
                        the Free Software Foundation, either version 3 of the License, or
                        (at your option) any later version.</p>
                    <p>This program is distributed in the hope that it will be useful,
                        but WITHOUT ANY WARRANTY; without even the implied warranty of
                        MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
                        GNU General Public License for more details.</p>
                </availability>
            </publicationStmt>
            <sourceDesc>
                <p>Generated by <ref target="http://tei-publisher.com">TEI Publisher</ref>
                </p>
                <p>born digital</p>
            </sourceDesc>
        </fileDesc>
        <encodingDesc>
            <tagsDecl>
                <pb:behaviour ident="img">
                      <pb:param name="src"/>
                      <pb:param name="width"/>
                      <pb:param name="height"/>
                      <pb:param name="title"/>
                      <pb:template xmlns="" xml:space="preserve">
                        <img src="[[src]]" width="[[width]]" height="[[height]]" title="[[title]]"/>
                    </pb:template>
                 </pb:behaviour>
                <rendition source="sv-custom.css"/>
            </tagsDecl>
        </encodingDesc>
        <revisionDesc>
            <change when="2021-05-11+02:00">Initial version</change>
        </revisionDesc>
    </teiHeader>
    <text>
<body>
     <schemaSpec start="TEI teiCorpus" ident="andersen" source="teipublisher.odd">
          <!-- <schemaSpec start="TEI teiCorpus" ident="teipublisher" tei_simplePrint.odd -->
                <elementSpec ident="text" mode="change">
                    <model behaviour="body"/>
                </elementSpec>

          

<!--NHB: 2024-05-06 reintroduced img-->
          <elementSpec ident="img" mode="add">
                    <model output="print" behaviour="omit"/>
                    <model output="epub" behaviour="omit"/>
                    <model behaviour="pass-through">
            <desc>2023-06-06: workaround to display images in the web output. 2024-09-10: Removed the absolute path hcandersen.dk to keep stress from webserver</desc>
            <param name="src" value="@src"/>
            <param name="title" value="@title"/>
                         <pb:template xmlns="" xml:space="preserve"><img class="illustration tei-img" src="https://hcandersen.dk/wp-content/uploads/[[src]]" title="[[title]]"/></pb:template>
                         <!--<img class="illustration tei-img" src="/wp-content/uploads/[[src]]" title="[[title]]"/>-->
        </model>
                </elementSpec>


          <!--NHB: 2023-06-16 updated seg to cover dfnStart and dfnEnd-->
          


          <elementSpec ident="seg" mode="change">
                    <model predicate="ancestor::choice[@type=&#34;unison&#34;]" behaviour="inline" cssClass="seg-unison"/>
                    <model output="print" predicate="@type=&#34;dfnStart&#34;" behaviour="omit"/>
                    <model output="epub" predicate="@type=&#34;dfnStart&#34;" behaviour="omit"/>
                    <modelSequence output="print" predicate="@target">
            <desc>All segments that are not dnfStart or dnfEnd need their content and a footnote in print output</desc>
            <model behaviour="inline"/>
            <model behaviour="note">
                <param name="content" value="let $n := @target return $get(.)/ancestor::TEI//table[@rend='textcomments']//row[@xml:id=$n]/cell[@type='data-definition']"/>
                <param name="place" value="'endnote'"/>
                 <outputRendition>font-style: normal; font-size: 0.8rem;</outputRendition>
            </model>
        </modelSequence>
                    <modelSequence output="epub" predicate="@target">
                         <desc>All segments that are not dnfStart need their content and a footnote in print output. 2024-09-17: added outputRendition font-style: normal</desc>
            <model behaviour="inline"/>
            <model behaviour="note">
                <param name="content" value="let $n := @target return $get(.)/ancestor::TEI//table[@rend='textcomments']//row[@xml:id=$n]/cell[@type='data-definition']"/>
                <param name="place" value="'endnote'"/>
                 <outputRendition>font-style: normal; font-size: 0.8rem;</outputRendition>
            </model>
        </modelSequence>
                    <model output="web" predicate="@type='dfnStart'" behaviour="alternate" cssClass="txtcomment">
            <param name="default" value="'▶'"/>
            <param name="alternate" value="let $n := @target return $get(.)/ancestor::TEI//table[@rend='textcomments']//row[@xml:id=$n]/cell[@type='data-definition']/node()"/>
            <outputRendition xml:space="preserve">
            color: lightslategray;
            <!--color: green;-->
            </outputRendition>
        </model>
                    <model output="web" behaviour="alternate" cssClass="txtcomment">
            <param name="default" value="."/>
            <param name="alternate" value="let $n := @target return $get(.)/ancestor::TEI//table[@rend='textcomments']//row[@xml:id=$n]/cell[@type='data-definition']/node()"/>
                         <outputRendition xml:space="preserve">
color: lightslategray;
            <!--color: green;-->
            </outputRendition>
        </model>
                    <model output="web" predicate="@type='dfnEnd'" behaviour="alternate" cssClass="txtcomment">
            <param name="default" value="'◀'"/>
            <param name="alternate" value="let $n := @target return $get(.)/ancestor::TEI//table[@rend='textcomments']//row[@xml:id=$n]/cell[@type='data-definition']/node()"/>
                         <outputRendition xml:space="preserve">
color: lightslategray;
            <!--color: green;-->
            </outputRendition>
        </model>
                </elementSpec>

                <elementSpec ident="figure" mode="change">

                     <model predicate="@type='longLine'" behaviour="block">
                          <outputRendition xml:space="preserve">
            text-align: center;
            </outputRendition>
                     </model>
                    <model predicate="head or @rendition='simple:display'" behaviour="block"/>
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="head" mode="change">
                    <model predicate="@type='main'" behaviour="heading">
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            font-weight: bold;
font-size: 2rem;
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                     <model predicate="@type='sub' or @type='part'" behaviour="heading">
                          <desc>added @type='sub'</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            font-weight: bold;
font-size: 1.3rem;
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                     <model predicate="@type='melody'" behaviour="block">
                          <desc>references to melodies, especially when nested in floatingText. 2024-05-28 removed type=sub and subtype=melody</desc>
                          <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            font-style:italic;
margin-top: 2rem;
margin-bottom: 2rem;
margin-left: 2rem;
font-size: 0.8rem;
            
            
            
            
            
            
            
            
            </outputRendition>
                     </model>
                    <!--<model predicate="@type='melody'" behaviour="inline">
            <desc>references to melodies, especially when nested in floatingText</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            font-style:italic;
margin-top: 2rem;
margin-bottom: 2rem;
margin-left: 2rem;
font-size: 0.9rem;
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>-->
                    <model predicate="@rend='supplied' and @type='section'" behaviour="inline">
            <desc>supplied titles with grey font-color</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            color:grey;
font-size: 1.8rem;
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="$parameters?header='short'" behaviour="inline">
            <param name="content" value="replace(string-join(.//text()[not(parent::ref)]), '^(.*?)[^\w]*$', '$1')"/>
        </model>
                    <model predicate="parent::figure" behaviour="heading">
            <outputRendition xml:space="preserve">
            font-style: italic;
            </outputRendition>
        </model>
                    <model predicate="parent::table" behaviour="heading">
            <outputRendition xml:space="preserve">
            font-style: italic;
            </outputRendition>
        </model>
                    <model predicate="parent::lg" behaviour="heading">
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            font-size: 24px;
margin-left: 1rem;
padding-bottom: 1rem;
padding-top: 1rem;
font-weight: bold;
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="parent::list" behaviour="heading">
            <outputRendition xml:space="preserve">
            font-weight: bold;
            </outputRendition>
        </model>
                    <model predicate="parent::div and preceding-sibling::head[position()=1]" behaviour="heading">
                         <desc>26px>1.3rem</desc>
            <param name="level" value="count(ancestor::div)"/>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            font-size: 1.3rem;
font-weight: bold;
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="parent::div and not(preceding-sibling::head[position()=1])" behaviour="heading">
<desc>2024-09-25: changed from 26px to 1.3rem</desc>
            <param name="level" value="count(ancestor::div)"/>
            <outputRendition xml:space="preserve">         
            
            
            
            
            
            
            
            font-size: 1.3rem;
font-weight: bold;
padding-top: 2rem;
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model behaviour="heading"/>
                </elementSpec>
                <elementSpec ident="teiHeader" mode="change">
                    <model output="epub" behaviour="block">
            <desc>Assemble colophon</desc>
            <param name="title" value="(.//titleStmt//title/string())[1]"/>
            <param name="author" value="(.//titleStmt/author)[1]"/>
            <param name="bibl" value="(.//sourceDesc/listBibl/bibl)[1]"/>
            <param name="cite" value="(.//xenoData[@type=&#34;citation&#34;]/cite)[1]"/>
            <param name="version" value=".//publicationStmt//idno"/>
            <param name="date" value=".//publicationStmt//date"/>
            <param name="availability" value=".//publicationStmt//availability/p"/>
            <param name="licence" value=".//publicationStmt//availability/licence"/>
            <pb:template xmlns="" xml:space="preserve"><div class="colophon">
  <h1>[[title]]</h1>
    <h3>af</h3>
  <h2>[[author]]</h2>
  
  <p>[[bibl]]</p>
  
  <div class="smaller">
    <img src="logo_andersen.svg" alt="HC Andersen logo: silhouette and signature"/>
    <h3>Filen er hentet fra <a href="https://hcandersen.dk/" target="_blank">hcandersen.dk</a></h3>
    <p><emph>Anbefalet henvisning</emph> [[cite]]</p>
    <p class="emph">Version [[version]] fra [[date]]</p>
    <p>For nærmere oplysninger om licensen og vilkår for brug, se [[licence]]</p>
    <p>[[availability]]</p>
  </div>
  
  <p><a href="https://hcandersen.dk/" target="_blank">Hcandersen.dk</a> er skabt af H.C. Andersen Centret ved Syddansk Universitet i samarbejde med Museum Odense og med bidrag fra Det Danske Sprog- og Litteraturselskab. Sitet
blev udviklet med støtte fra Kulturministeriet.</p>
  <img src="SDU-logo.svg" alt="SDU Logo"/>
  <br/>
  <img src="hca.svg" alt="H C Andersen Hus"/>
  <img src="kultur.svg" alt="Kultur Ministeriet Logo"/>
</div></pb:template>
        </model>
                    <model output="print" behaviour="block">
            <desc>Assemble colophon</desc>
            <param name="title" value="(.//titleStmt//title/string())[1]"/>
            <param name="author" value="(.//titleStmt/author)[1]"/>
            <param name="bibl" value="(.//sourceDesc/listBibl/bibl)[1]"/>
            <param name="cite" value="(.//xenoData[@type=&#34;citation&#34;]/cite)[1]"/>
            <param name="version" value=".//publicationStmt//idno"/>
            <param name="date" value=".//publicationStmt//date"/>
            <param name="availability" value=".//publicationStmt//availability/p[1]"/>
            <!--<param name="licence" value=".//publicationStmt//availability/licence"/>-->
            <param name="base" value="$global:context-path"/>
            <pb:template xmlns="" xml:space="preserve"><div class="colophon">
  <h1>[[title]]</h1>
    <h3>af</h3>
  <h2>[[author]]</h2>
  
  <p>[[bibl]]</p>
  
  <div class="smaller">
    <img src="resources/images/logo_andersen.svg" alt="HC Andersen logo: silhouette and signature"/>
    <h3>Filen er hentet fra <a href="https://hcandersen.dk/" target="_blank">hcandersen.dk</a></h3>
    <p><emph>Anbefalet henvisning</emph> [[cite]]</p>
    <p class="emph">Version [[version]] fra [[date]]</p>
    <p>For nærmere oplysninger om licensen og vilkår for brug, se [[licence]]</p>
    <p>[[availability]]</p>
  </div>
  
  <p><a href="https://hcandersen.dk/" target="_blank">Hcandersen.dk</a> er skabt af H.C. Andersen Centret ved Syddansk Universitet i samarbejde med Museum Odense og med bidrag fra Det Danske Sprog- og Litteraturselskab. Sitet
blev udviklet med støtte fra Kulturministeriet.</p>
  <img src="resources/images/SDU-logo.svg" alt="SDU Logo"/>
  <br/>
  <img src="resources/images/hca.svg" alt="H C Andersen Hus"/>
  <img src="resources/images/kultur.svg" alt="Kultur Ministeriet Logo"/>
</div></pb:template>
        </model>
                    <model output="latex" behaviour="metadata"/>
                    <model output="fo" behaviour="omit"/>
                    <model output="latex" predicate="$parameters?header='short'" behaviour="block">
            <desc>2024-03-13 changed output from web&gt;latex in to disable output</desc>
        </model>
                </elementSpec>
                <elementSpec ident="fileDesc" mode="change">
                    <modelSequence predicate="$parameters?header='short'">
            <model behaviour="block" cssClass="header-short">
                <param name="content" value="titleStmt"/>
            </model>
            <model behaviour="block" cssClass="header-short">
                <param name="content" value="editionStmt"/>
            </model>
            <model behaviour="block" cssClass="header-short">
                <param name="content" value="publicationStmt"/>
            </model>
        </modelSequence>
                    <model behaviour="title">
            <param name="content" value="titleStmt"/>
        </model>
                </elementSpec>
                <!--<elementSpec ident="titleStmt" mode="add">
                    <model output="latex" behaviour="meta">
            <param name="content" value="."/>
        </model>
                    <model output="fo" behaviour="heading"/>
                    <model predicate="$parameters?mode='title'" behaviour="heading">
            <param name="content" value="title[not(@type)]"/>
            <param name="level" value="5"/>
        </model>
                    <modelSequence output="web" predicate="$parameters?header='short'">
            <model behaviour="link">
                <param name="content" value="title[1]"/>
                <param name="uri" value="$parameters?doc"/>
            </model>
            <model behaviour="block">
                <param name="content" value="subsequence(title, 2)"/>
            </model>
            <model behaviour="block">
                <param name="content" value="author"/>
            </model>
        </modelSequence>
                    <model output="web" behaviour="block"/>
                </elementSpec>-->
                <elementSpec ident="publicationStmt" mode="add">
                    <model output="web" behaviour="block">
            <param name="content" value="availability"/>
        </model>
                    <model behaviour="omit"/>
                </elementSpec>
                <elementSpec ident="licence" mode="change">
                    <model output="web" predicate="@target" behaviour="link" cssClass="licence">
            <param name="content" value="'Licence aa'"/>
            <param name="uri" value="@target"/>
        </model>
                    <model behaviour="pass-through">
            <desc>For all outputs except web</desc>
            <param name="target" value="@target"/>
            <pb:template xmlns="" xml:space="preserve"><a href="[[target]]" target="_blank">[[content]]</a></pb:template>
        </model>
                </elementSpec>
                <elementSpec ident="title" mode="change">
                    <model predicate="@type=&#34;main&#34; and ancestor::body" behaviour="paragraph">
            <desc>main titles</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            font-size: 30px;
text-align: center;
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="@type=&#34;sub&#34; and ancestor::body" behaviour="paragraph">
                         <desc>subtitles. 2024-09-25: 26px>1.3rem</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            font-size: 1.3rem;
text-align: center;
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model predicate="not(@level) and parent::bibl" behaviour="inline"/>
                    <modelSequence predicate="@level='m' or not(@level)">
            <model behaviour="omit">
                <outputRendition xml:space="preserve">
                font-style: italic;
                </outputRendition>
            </model>
            <model predicate="ancestor::biblFull" behaviour="text">
                <param name="content" value="', '"/>
            </model>
        </modelSequence>
                    <modelSequence predicate="@level='s' or @level='j'">
            <model behaviour="inline">
                <outputRendition xml:space="preserve">
                font-style: italic;
                </outputRendition>
            </model>
            <model predicate="following-sibling::* and     (  ancestor::biblFull)" behaviour="text">
                <param name="content" value="', '"/>
            </model>
        </modelSequence>
                    <modelSequence predicate="@level='u' or @level='a'">
            <model behaviour="inline">
                <outputRendition xml:space="preserve">
                font-style: italic;
                </outputRendition>
            </model>
            <model predicate="following-sibling::* and     (    ancestor::biblFull)" behaviour="text">
                <param name="content" value="'. '"/>
            </model>
        </modelSequence>
                    <model predicate="not(ancestor::sourceDesc)" behaviour="inline">
            <outputRendition xml:space="preserve">
            font-style: italic;
            </outputRendition>
        </model>
                </elementSpec>
                <elementSpec ident="author" mode="change">
                    <model behaviour="inline"/>
                </elementSpec>
                <elementSpec ident="edition" mode="change">
                    <model predicate="ancestor::teiHeader" behaviour="block">
            <outputRendition xml:space="preserve" scope="before">
            content: 'Edition: ';
            </outputRendition>
        </model>
                </elementSpec>
            <elementSpec ident="ref" mode="change">
                    <model predicate="not(@target)" behaviour="inline"/>
                    <model predicate="not(node())" behaviour="link">
            <param name="content" value="@target"/>
            <param name="uri" value="@target"/>
        </model>
                    <model behaviour="link">
            <param name="uri" value="@target"/>
        </model>
                </elementSpec>
            <elementSpec ident="note" mode="change">
                 <desc>2024-12-11: added predicate="@type='footnote'". Maybe extend to include: and not(//teiHeader//titleStmt/title/@type='intro')</desc>
                 <model predicate="@type='footnote'" behaviour="note" cssClass="note-author">
            <param name="place" value="@place"/>
            <param name="label" value="@n"/>
        </model>
                </elementSpec>
            <elementSpec ident="notatedMusic" mode="add">
                    <model behaviour="figure">
            <param name="title" value="label"/>
            <param name="content" value="ptr"/>
        </model>
                </elementSpec>
                <elementSpec ident="ptr" mode="add">
                    <model predicate="parent::notatedMusic" behaviour="webcomponent">
            <param name="name" value="'pb-mei'"/>
            <param name="url" value="@target"/>
        </model>
                </elementSpec>
            <elementSpec ident="p" mode="change">
                    <model predicate="ancestor::note" behaviour="inline" cssClass="note-p">
            <desc>set a class to distinguish p which is a part of a note</desc>
        </model>
                    <model predicate="@rend='firstIndent' and ancestor::set" behaviour="paragraph" useSourceRendition="true">
            <outputRendition xml:space="preserve">
            
            margin-top:auto;
margin-bottom:auto;
            font-size:0.9rem;
text-align: justify;
text-indent: 1rem;
            
            </outputRendition>
        </model>
                    <model predicate="ancestor::set and @rend='noIndent'" behaviour="paragraph">
            <desc>2024-03-13: removed margin-top</desc>
            <outputRendition xml:space="preserve">
            
            font-size:0.9rem;
text-align: justify;
            
            </outputRendition>
        </model>
                    <modelGrp>
            <model predicate="@rend='noIndent'" behaviour="paragraph">
                <outputRendition xml:space="preserve">
                
                text-align: justify;
margin-top:auto;
margin-bottom:auto;
                
                </outputRendition>
            </model>
            <model predicate="@rend='center'" behaviour="paragraph">
                <outputRendition xml:space="preserve">
                
                text-align: center;
margin-top:auto;
margin-bottom:auto;
                
                </outputRendition>
            </model>
            <model predicate="@rend='firstIndent'" behaviour="paragraph" useSourceRendition="true">
                <outputRendition xml:space="preserve">
                
                text-align: justify;
text-indent: 1rem;
margin-top:auto;
margin-bottom:auto;
                
                </outputRendition>
            </model>
            <model predicate="@rend='right'" behaviour="paragraph">
                <outputRendition xml:space="preserve">
                
                text-align: right;
margin-top:auto;
margin-bottom:auto;
                
                </outputRendition>
            </model>
                         <model behaviour="paragraph" predicate="@rend='padding'">
                              <outputRendition xml:space="preserve">
                
                margin-top: 1rem;
margin-bottom: auto;
text-align: justify;
                </outputRendition>
                         </model>

            <model behaviour="paragraph">
                <outputRendition xml:space="preserve">
                
                margin-top:auto;
margin-bottom:auto;
                
                </outputRendition>
            </model>
        </modelGrp>
                </elementSpec>
            <elementSpec ident="lg" mode="change">
                    <model predicate="ancestor::sp" behaviour="block">
            <desc>2023-12-01: 1) increased 22 &gt; 25 rem; older: 1) Changed from 17 rem to 22 rem 2) Limit max-width to drama through predicate sp (formerly div @type="scene") 3) behaviour: paragraph &gt; block. 2024-09-28: increase to 40rem</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            
            min-width: fit-content; 
            margin-top: 1rem;
margin-bottom: 1rem;
max-width: 40rem;
            
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                    <model behaviour="block">
            <desc>Outside drama</desc>
            <outputRendition xml:space="preserve">
            
            
            
            
            
            
            
            margin-top: 1rem;
            margin-bottom: 1rem;
            
            
            
            
            
            
            
            </outputRendition>
        </model>
                </elementSpec>
          <elementSpec ident="l" mode="change">
               <model behaviour="cell" predicate="ancestor::spGrp">
                    <desc>added 2024-09-10</desc>
               </model>
               <model behaviour="paragraph" useSourceRendition="true">
                    <desc>2024-06-13: reset styling. Finetuning of indents via css</desc>
                    <outputRendition xml:space="preserve"/>
               </model>
               
               <!--
                 <model predicate="ancestor::*[rendition='verse'] and not(@rend)" behaviour="paragraph">
                      <outputRendition xml:space="preserve">margin-left: 0rem;</outputRendition>
                 </model>
                                     
                 <model predicate="(not(@rend)) or (ancestor::*[rendition='verse'] and @rend='firstIndent')" behaviour="paragraph">
            <outputRendition xml:space="preserve">            
            
            margin-left: 3rem;
margin-top:auto;
margin-bottom:auto;
            
            
            </outputRendition>
        </model>
                    <model predicate="@rend='center'" behaviour="paragraph">
            <outputRendition xml:space="preserve">
            
            
            text-align: center;
margin-top: 1rem;
margin-top:auto;
margin-bottom:auto;
            
            
            </outputRendition>
        </model>
                 <model predicate="(ancestor::lg or ancestor::floatingText[@type='song']) and @rend='firstIndent'" behaviour="paragraph" useSourceRendition="true">
            <outputRendition xml:space="preserve">
            
            
            margin-left: 4rem;
margin-top:auto;
margin-bottom:auto;
            
            
            </outputRendition>
        </model>
                    <model predicate="@rend='right'" behaviour="paragraph">
            <outputRendition xml:space="preserve">
            
            
            text-align: right;
margin-top:auto;
margin-bottom:auto;
            
            
            </outputRendition>
        </model>
                    <model predicate="@rend" behaviour="paragraph">
            <outputRendition xml:space="preserve">            

            
            margin-top:auto;
margin-bottom:auto;
            
            
            </outputRendition>
        </model>
