                </elementSpec>
            <elementSpec ident="choice" mode="change">
                 <model predicate="@type='role'" behaviour="cell" cssClass="choice-role"></model>
                 <model predicate="@type='actor'" behaviour="cell" cssClass="choice-actor"></model>
                 <model predicate="@type='unison'" behaviour="inline" cssClass="choice-unison">
                      <desc>@type='unison'</desc>
                 </model>
                    <model predicate="sic and corr" behaviour="alternate">
            <param name="default" value="corr[1]"/>
            <param name="alternate" value="sic[1]"/>
        </model>
                    <model predicate="abbr and expan" behaviour="alternate">
            <param name="default" value="expan[1]"/>
            <param name="alternate" value="abbr[1]"/>
        </model>
                    <model predicate="orig and reg" behaviour="alternate">
            <param name="default" value="reg[1]"/>
            <param name="alternate" value="orig[1]"/>
        </model>
                </elementSpec>
            <elementSpec ident="spGrp" mode="change">
                    <model predicate="@type=&#34;unison&#34;" behaviour="block">
            <param name="unison" value="stage"/>
            <param name="sp" value="sp"/>
            <pb:template xmlns="" xml:space="preserve"><div class="sp-unison">
  <div class="unison-left">[[unison]]</div>
  <div class="unison-right">[[sp]]</div>
</div></pb:template>
        </model>
                 <model predicate="@type='table'" behaviour="table" useSourceRendition="true">
                      <desc>Used in kjaerlighed-paa-nicolai-taarn-eller-hvad-siger-parterret.xml</desc>
                      <outputRendition xml:space="preserve"></outputRendition>
                 </model>
                    <model behaviour="block"/>
                </elementSpec>

          
          <!--additions by NHB follow-->
          <elementSpec ident="actor" mode="change">
               <model predicate="parent::choice" behaviour="block">
                    <outputRendition xml:space="preserve">
            padding-left: 1vw;
            </outputRendition>
               </model>
               <model behaviour="cell">
                    <outputRendition xml:space="preserve">
            min-width:max-content;
padding-left: 2vw;
            </outputRendition>
               </model>
          </elementSpec>
          <elementSpec ident="castGroup" mode="change">
               <model predicate="@type='blank'" behaviour="inline">
                    <desc>does not achieve the desired effect of inserting a blank row inside the castList-table</desc>
                    <pb:template xmlns="" xml:space="preserve"><row><cell/></row></pb:template>
               </model>
               <model behaviour="row"/>
          </elementSpec>
          <elementSpec ident="castItem" mode="change">
               <model behaviour="row">
                    <desc>Insert item, rendered as described in parent list rendition. </desc>
               </model>
          </elementSpec>
          <elementSpec ident="castList" mode="change">
               <model predicate="child::*" behaviour="table" useSourceRendition="true">
                    <outputRendition xml:space="preserve">
            font-size: 0.9rem;
 border-collapse: separate;
border-spacing: 0 10px;
            </outputRendition>
               </model>
          </elementSpec>
          <elementSpec ident="role" mode="change">
               <model predicate="parent::choice" behaviour="block"/>
               <model behaviour="cell"/>               
<!--<model behaviour="block"/>-->
          </elementSpec>
          <elementSpec ident="roleDesc" mode="change">
               <model behaviour="cell"/>
          </elementSpec>
          <elementSpec ident="performance" mode="add">
               <model behaviour="block">
                    <outputRendition xml:space="preserve">
            padding-top: 10vw;
            </outputRendition>
               </model>
          </elementSpec>
          <elementSpec ident="graphic" mode="change">
               <model predicate="@type='blank'" behaviour="section">
                    <pb:template xmlns="" xml:space="preserve"><br/></pb:template>
               </model>
          </elementSpec>
          <elementSpec ident="app" mode="add">
               <model behaviour="inline" predicate="//teiHeader//listBibl//biblStruct//editor/@ref='http://viaf.org/viaf/4925902'"/>
          </elementSpec>
          <elementSpec ident="rdg" mode="add">
<desc>2024-12-11: added predicate to restrict this behaviour to the SV app</desc>
               <model behaviour="omit" predicate="//teiHeader//listBibl//biblStruct//editor/@ref='http://viaf.org/viaf/4925902'"/>
          </elementSpec>
          <elementSpec ident="lem" mode="add">
               <desc>2024-12-11: added predicate to restrict this behaviour to the SV app</desc>
               <model behaviour="alternate" cssClass="errata"  predicate="//teiHeader//listBibl//biblStruct//editor/@ref='http://viaf.org/viaf/4925902'">
                    <param name="default" value="."/>
                    <param name="alternate" value="&#34;rettet ordlyd. Ordlyden i den trykte 18-binds-udgave er fejlbehæfter og lyder som følger: '&#34; ||  following-sibling::rdg ||&#34;'.&#34;"/>
                    <outputRendition xml:space="preserve">
            color: darkorange;
            </outputRendition>
               </model>
          </elementSpec>
            </schemaSpec>
        </body>        
    </text>
</TEI>

